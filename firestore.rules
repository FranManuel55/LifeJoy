rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // REGLA: Perfil de usuario
    // Solo el dueño puede leer/escribir su perfil
    // =============================================
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // =============================================
      // REGLA: Game State del usuario
      // Solo el dueño puede leer/escribir su game state
      // Validaciones de integridad de datos
      // =============================================
      match /gamestate/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;

        allow write: if request.auth != null 
                     && request.auth.uid == userId
                     && validateGameState(request.resource.data);
      }
    }

    // =============================================
    // FUNCIONES DE VALIDACIÓN
    // =============================================

    // Validar que el game state tenga estructura válida
    function validateGameState(data) {
      return data.keys().hasAny(['life', 'categories', 'tasks'])
             && (data.life is int || data.life is float)
             && data.life >= 0
             && data.life <= 100;
    }
  }
}